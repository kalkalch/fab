# FAB - Firewall Access Bot Configuration Template
# Copy this file to .env and fill in your actual values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Web Server Configuration  
HTTP_PORT=8080
HOST=0.0.0.0
SITE_URL=http://your-domain.com:8080

# Security Configuration
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or with openssl: openssl rand -base64 32
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRY=3600

# API proxy (empty = not used). Used for requests to Telegram/VK API.
# TELEGRAM_API_PROXY=
# VK_API_PROXY=

# Backup site URL for access link. If set, shown with indent on one line under main link. If empty, not used.
# SITE_BACKUP_URL=

# Proxy Configuration
# Set to true when running behind nginx proxy, false for direct access
NGINX_ENABLED=false

# MQTT Configuration
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=fab-bot
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_QOS=1
MQTT_TOPIC_PREFIX=mikrotik/whitelist/ip

# Logging Configuration
LOG_LEVEL=INFO

ADMIN_TELEGRAM_IDS=""

# VK Bot (optional). Off by default; set VK_ENABLED=true and token to run.
# See https://dev.vk.com/api/bots-long-poll
# VK_ENABLED=false
# VK_BOT_TOKEN=
# ADMIN_VK_IDS=
# VK_GROUP_ID=